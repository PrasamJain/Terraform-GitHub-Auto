{
  "aws_region": "us-east-1",

  "ec2_instances": {
    "web-server": {
      "ami":           "ami-0c02fb55956c7d316",
      "instance_type": "t3.micro",
      "key_name":      "",
      "tags": {
        "Environment": "dev",
        "Role":        "web"
      }
    },
    "app-server": {
      "ami":           "ami-0c02fb55956c7d316",
      "instance_type": "t3.small",
      "key_name":      "",
      "tags": {
        "Environment": "dev",
        "Role":        "app"
      }
    }
  },

  "s3_buckets": {
    "prasamjain-app-uploads": {
      "versioning_enabled": true,
      "force_destroy":      false,
      "tags": {
        "Environment": "dev",
        "Purpose":     "app-uploads"
      }
    },
    "prasamjain-logs": {
      "versioning_enabled": false,
      "force_destroy":      true,
      "tags": {
        "Environment": "dev",
        "Purpose":     "logs"
      }
    }
  },

  "iam_users": {
    "dev-user": {
      "path":        "/",
      "policy_arns": [
        "arn:aws:iam::aws:policy/ReadOnlyAccess"
      ],
      "tags": {
        "Environment": "dev",
        "Team":        "engineering"
      }
    },
    "ci-bot": {
      "path":        "/bots/",
      "policy_arns": [
        "arn:aws:iam::aws:policy/AmazonS3FullAccess",
        "arn:aws:iam::aws:policy/AmazonEC2ReadOnlyAccess"
      ],
      "tags": {
        "Environment": "dev",
        "Team":        "devops"
      }
    }
  }

}
